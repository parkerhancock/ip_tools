# ip-tools MCP server environment variables
# Copy to /opt/ip-tools/.env and fill in values
# chmod 600 /opt/ip-tools/.env
#
# Canonical names are LAW_TOOLS_CORE_* (the shared scaffolding package).
# Legacy LAW_TOOLS_* names are accepted as aliases for backward
# compatibility with law-tools deployments — either prefix works.

# Bearer token for MCP HTTP auth (required for deployed server).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
LAW_TOOLS_CORE_API_KEY=

# Public base URL for download links (enables HMAC-signed download URLs).
# Leave empty for local/stdio mode (downloads use tempfiles instead).
LAW_TOOLS_CORE_PUBLIC_URL=https://mcp.example.com/ip_tools

# Optional: rotation window for HMAC-signed download URLs, in seconds.
# Default 86400 (24h). Effective URL lifetime is 1-2x this value due to
# bucket-grace verification.
# LAW_TOOLS_CORE_DOWNLOAD_TTL_SECONDS=86400

# Optional: on-disk cache dir for downloaded documents.
# Default: ~/.cache/law_tools_core/downloads
# LAW_TOOLS_CORE_DOWNLOAD_CACHE=/var/cache/ip-tools/downloads

# Optional: directory for tool-call JSONL logs (ToolCallLogger middleware).
# Leave unset to disable structured tool-call logging.
# LAW_TOOLS_CORE_LOG_DIR=/var/log/ip-tools

# --- Data-source credentials ---------------------------------------------

# USPTO Open Data Portal (patents, applications, PTAB, petitions, bulk data).
# Request at https://data.uspto.gov/. Free.
USPTO_ODP_API_KEY=

# EPO Open Patent Services (European patents, CPC classification).
# Register at https://developers.epo.org/. Free tier: 4 GB/week.
EPO_OPS_API_KEY=
EPO_OPS_API_SECRET=

# Japan Patent Office (application status). Optional — disabled by default.
# Contact JPO for credentials; most deployments leave these unset.
# JPO_API_USERNAME=
# JPO_API_PASSWORD=
