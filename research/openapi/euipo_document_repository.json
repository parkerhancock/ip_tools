  "paths": {
    "/documents": {
      "post": {
        "operationId": "createDocument",
        "summary": "Uploads a document to the user's temporal storage and returns the associated identifier",
        "description": "Creates a temporal document",
        "tags": [
          "Documents"
        ],
        "security": [
          {
            "ClientID": [],
            "Oauth2AuthorizationCode": [
              "document-repository.documents.write"
            ]
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "description": "The file to upload.",
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/Document"
          },
          "400": {
            "$ref": "#/components/responses/QuotaError"
          },
