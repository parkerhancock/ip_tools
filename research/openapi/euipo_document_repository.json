            "$ref": "#/components/responses/UnauthorizedError"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitError"
          },
          "default": {
            "$ref": "#/components/responses/DefaultError"
          }
        }
      },
      "get": {
        "operationId": "getDocuments",
        "summary": "Retrieves a list of the user documents with pagination.",
        "description": "Retrieves a list of the user documents with pagination.",
        "tags": [
          "Documents"
        ],
        "security": [
