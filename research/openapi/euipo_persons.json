                },
                "totalPages": {
                  "$ref": "#/components/schemas/TotalPages"
                },
                "size": {
                  "$ref": "#/components/schemas/PageSize"
                },
                "page": {
                  "$ref": "#/components/schemas/PageNumber"
                }
              },
              "example": {
                "applicants": [
                  {
                    "identifier": 203161,
                    "type": "APPLICANT_BUSINESS",
                    "name": "Firstname 203161 Owner 203161",
                    "address": {
                      "street": "Address of owner 203161",
                      "city": "Irvine",
                      "postalCode": "92618",
                      "state": "US-VA",
                      "country": "US"
                    },
                    "correspondenceAddress": {
                      "formattedAddress": "Correspondence address of owner 203161"
