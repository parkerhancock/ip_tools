    "schemas": {
      "PageNumber": {
        "type": "integer",
        "format": "int32",
        "default": 0,
        "example": 0,
        "description": "The results are returned in pages. The page parameter (zero-based) indicates which page to return. For example, page = 2 (third page) and size = 10 will return matching applications No 21 to No 30"
      },
      "PageSize": {
        "type": "integer",
        "format": "int32",
        "default": 20,
        "example": 10,
        "description": "Number of results to fetch per page"
      },
      "TotalElements": {
        "type": "integer",
        "format": "int32",
        "example": 1
      },
      "TotalPages": {
        "type": "integer",
        "format": "int32",
        "example": 1
      },
      "ApplicantSearchItem": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/ApplicantType"
          },
          "name": {
            "type": "string",
            "description": "Applicant's full name"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "correspondenceAddress": {
            "$ref": "#/components/schemas/Address"
          }
        },
        "additionalProperties": false
      },
      "Applicant": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/ApplicantBusiness"
          },
          {
            "$ref": "#/components/schemas/ApplicantIndividual"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "APPLICANT_BUSINESS": "#/components/schemas/ApplicantBusiness",
            "APPLICANT_INDIVIDUAL": "#/components/schemas/ApplicantIndividual"
          }
        }
      },
      "ApplicantBusiness": {
        "type": "object",
        "description": "Legal entity applicant",
        "properties": {
          "identifier": {
            "$ref": "#/components/schemas/PERIdentifier"
          },
          "type": {
            "type": "string",
            "enum": [
              "APPLICANT_BUSINESS"
            ],
            "description": "Applicant type"
          },
          "legalName": {
            "type": "string",
            "maxLength": 350,
            "description": "Name of the company"
          },
          "legalForm": {
            "type": "string",
            "maxLength": 250,
            "description": "Legal form used by the company. It may differ per country."
          },
          "nationalIdentification": {
            "type": "string",
            "description": "Company’s national identification"
          },
          "countryOfIncorporation": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Country"
              }
            ],
            "description": "Nationality of the company"
          },
          "stateOfIncorporation": {
            "type": "string",
            "format": "iso-3166-2",
            "description": "State, District, or Territory of incorporation (For US applicants)"
          },
          "employees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RelatedMember"
            },
            "description": "Employees of the legal entity"
          },
          "address": {
            "$ref": "#/components/schemas/LegalAddress"
          },
          "correspondenceAddress": {
            "$ref": "#/components/schemas/ApplicantCorrespondenceAddress"
          },
          "phone": {
            "$ref": "#/components/schemas/Phone"
          },
          "email": {
            "$ref": "#/components/schemas/Email"
          }
        },
        "additionalProperties": false,
        "required": [
          "identifier",
          "type",
          "legalName",
          "countryOfIncorporation",
          "address"
        ],
        "example": {
          "identifier": 1234,
          "type": "APPLICANT_BUSINESS",
          "legalName": "MIA CAROLA, S.L.",
          "countryOfIncorporation": "ES",
          "address": {
            "street": "Paseo Ruiseñores, 14-16, 10ºB",
            "city": "ALICANTE",
            "country": "ES"
          }
        }
      },
      "ApplicantIndividual": {
        "type": "object",
        "description": "Natural person applicant",
        "properties": {
          "identifier": {
            "$ref": "#/components/schemas/PERIdentifier"
          },
          "type": {
            "type": "string",
            "enum": [
              "APPLICANT_INDIVIDUAL"
            ],
            "description": "Applicant type"
          },
          "firstName": {
            "$ref": "#/components/schemas/FirstName"
          },
          "surname": {
            "$ref": "#/components/schemas/Surname"
          },
          "nationality": {
            "$ref": "#/components/schemas/Nationality"
          },
          "address": {
            "$ref": "#/components/schemas/LegalAddress"
          },
