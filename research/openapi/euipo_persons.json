    "responses": {
      "ApplicantSearchResult": {
        "description": "List of applicants that match the search criteria",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "applicants": {
                  "type": "array",
                  "items": {
