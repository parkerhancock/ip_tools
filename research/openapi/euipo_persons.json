        ]
      },
      "RepresentativeType": {
        "type": "string",
        "enum": [
          "REPRESENTATIVE_EMPLOYEE",
          "REPRESENTATIVE_LEGAL_ASSOCIATION",
          "REPRESENTATIVE_LEGAL_PROFESSIONAL",
          "REPRESENTATIVE_EUIPO_PROFESSIONAL"
        ]
      },
      "HttpLink": {
        "type": "string",
        "format": "uri"
      },
      "RelatedMember": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string"
          },
          "type": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/ApplicantType"
              },
              {
                "$ref": "#/components/schemas/RepresentativeType"
              }
            ]
          },
          "href": {
            "$ref": "#/components/schemas/HttpLink"
          }
        },
        "additionalProperties": false
      },
      "Problem": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "A short, human-readable summary of the problem type\n"
          },
          "detail": {
            "type": "string",
            "description": "A human-readable explanation specific to this occurrence of the problem\n"
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "The HTTP status code generated by the origin server for this occurrence of the problem\n"
          },
          "type": {
            "type": "string",
            "format": "uri",
            "description": "A URI reference [RFC3986] that identifies the\n      problem type.  This specification encourages that, when\n      dereferenced, it provide human-readable documentation for the\n      problem type\n"
          },
          "instance": {
            "type": "string",
            "format": "uri-reference",
            "description": "A URI reference that identifies the specific occurrence of the problem.\nIt may or may not yield further information if dereferenced\n"
          },
          "extensions": {
            "type": "object",
            "description": "Contains members that may convey additional, problem-specific information.\n"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        },
        "additionalProperties": false,
        "required": [
          "title",
          "detail"
        ]
      }
    }
